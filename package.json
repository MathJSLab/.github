{
    "name": "mathjslab-github",
    "version": "0.0.1",
    "description": "MathJSLab GitHub Organization profile.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MathJSLab/.github.git"
    },
    "author": "MathJSLab <mathjslab@gmail.com>",
    "homepage": "https://mathjslab.com/",
    "type": "module",
    "scripts": {
        "install:approve:all": "npm install-scripts approve --all && npm install",
        "update": "npx npm-check-updates -u -x typescript && npm install && npm run clean",
        "clean:package-lock": "node script/helper/clean-package-lock.cjs",
        "clean:build": "shx rm -rf images profile resource test README.md LEIAME.md LEAME.md",
        "clean:script": "shx rm -rf script/build",
        "clean:build:script": "npm run clean:script && npm run clean:build",
        "clean": "npm run clean:build:script",
        "clean:all": "npm run clean && npm run clean:package-lock",
        "pregit:add": "replace-in-file --verbose --configFile=replace.fix-linebreak.json",
        "git:add": "git add .",
        "git:commit": "node script/helper/git-commit.cjs",
        "git:push": "git push",
        "git:all": "npm run git:add && npm run git:commit && npm run git:push",
        "tsx": "tsx --require tsconfig-paths/register",
        "npx:tsx": "npx tsx",
        "crono:start": "npm run tsx script/helper/mark-crono.ts -- start",
        "crono:mark": "npm run tsx script/helper/mark-crono.ts -- mark",
        "crono:stop": "npm run tsx script/helper/mark-crono.ts -- stop",
        "format": "prettier --plugin=@prettier/plugin-xml --write **/*.{ts,tsx,js,jsx,cjs,mjs,css,scss,html,htm,json,jsonc,yml,yaml,xml,svg,md,yml,yaml}",
        "postformat": "replace-in-file --verbose --configFile=replace.fix-endnl.json",
        "lint": "eslint --fix",
        "format:lint": "npm run format && npm run lint",
        "code:stats": "npx cod-stat -c -f -a . --ignore .circleci lib node_modules report res",
        "code:stats:summary": "npx cod-stat -c -f -a . --ignore .circleci lib node_modules report res --json && shx mkdir -p report && shx cp code-stats/report.json report/code.stats.json && shx rm -rf code-stats && npm run tsx -- script/helper/code-stats.ts",
        "build:script": "tsc -p script/tsconfig.node.json",
        "prebuild": "npm run build:script",
        "build": "npm run clean:build && node eleventy.build.mjs",
        "mkdir:resource": "shx mkdir -p resource/mathjslab resource/mathjslab-app resource/mathjslab-www",
        "copy:prettierrc": "shx cp input/resource/mathjslab/.prettierrc resource/mathjslab/.prettierrc",
        "copy:repo": "shx cp input/resource/mathjslab/copy.repo.config.json resource/mathjslab/copy.repo.config.json && shx cp input/resource/mathjslab-app/copy.repo.config.json resource/mathjslab-app/copy.repo.config.json && shx cp input/resource/mathjslab-www/copy.repo.config.json resource/mathjslab-www/copy.repo.config.json",
        "postbuild": "npm run mkdir:resource && npm run copy:prettierrc && npm run copy:repo",
        "build:format:lint": "npm run build && npm run format:lint",
        "do:all": "npm run crono:start && npm run clean:all && npm run update && npm run format:lint && npm run build:format:lint && npm run git:all && echo script \"do:all\" finished. && npm run crono:stop"
    },
    "devDependencies": {
        "@11ty/eleventy": "^3.1.6",
        "@11ty/eleventy-img": "^6.0.4",
        "@prettier/plugin-xml": "^3.4.2",
        "@resvg/resvg-js": "^2.6.2",
        "@types/coffeescript": "^2.5.7",
        "@types/cson": "^7.20.3",
        "@types/eslint-config-prettier": "^6.11.3",
        "@types/micromatch": "^4.0.10",
        "@types/node": "^26.1.1",
        "@types/pngjs": "^6.0.5",
        "@typescript-eslint/eslint-plugin": "^8.65.0",
        "@typescript-eslint/parser": "^8.65.0",
        "chalk": "^5.6.2",
        "coffeescript": "^2.7.0",
        "cross-env": "^10.1.0",
        "cson": "^8.4.0",
        "dotenv": "^17.4.2",
        "dotenv-expand": "^13.0.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.6",
        "fast-xml-parser": "^5.10.1",
        "glob": "^13.0.6",
        "globals": "^17.7.0",
        "jimp": "^1.6.1",
        "json5": "^2.2.3",
        "micromatch": "^4.0.8",
        "node-html-parser": "^9.0.0",
        "png-to-ico": "^3.0.2",
        "prettier": "^3.9.5",
        "replace-in-file": "^8.4.0",
        "sass": "^1.101.3",
        "shelljs": "^0.10.0",
        "shx": "^0.4.0",
        "smol-toml": "^1.7.0",
        "ts-loader": "^9.6.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.23.1",
        "typescript": "^6.0.3",
        "uuid": "^14.0.1",
        "yaml": "^2.9.0"
    },
    "allowScripts": {
        "@parcel/watcher@2.5.6": true,
        "esbuild@0.28.1": true,
        "sharp@0.33.5": true
    }
}
